<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="omni_bot">

  <!-- ============================================================
       Omni-wheeled (mecanum) robot description
       Base brain: Raspberry Pi 4B | MCU: Arduino UNO
       Sensors: GY-9250 9DOF IMU, Pi Camera 3, (sim) 2D lidar
       ============================================================ -->

  <xacro:include filename="$(find omni_description)/urdf/inertial_macros.xacro"/>
  <xacro:include filename="$(find omni_description)/urdf/sensors.xacro"/>
  <xacro:include filename="$(find omni_description)/urdf/gazebo.xacro"/>

  <!-- Parameters -->
  <xacro:property name="base_length" value="0.30"/>
  <xacro:property name="base_width"  value="0.24"/>
  <xacro:property name="base_height" value="0.08"/>
  <xacro:property name="base_mass"   value="3.5"/>

  <xacro:property name="wheel_radius" value="0.048"/>
  <xacro:property name="wheel_width"  value="0.038"/>
  <xacro:property name="wheel_mass"   value="0.25"/>

  <!-- wheel mount offsets from base_link centre -->
  <xacro:property name="wheel_xoff" value="0.11"/>
  <xacro:property name="wheel_yoff" value="0.145"/>
  <xacro:property name="wheel_zoff" value="0.0"/>

  <!-- Materials -->
  <material name="grey"><color rgba="0.35 0.35 0.4 1.0"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="orange"><color rgba="0.9 0.45 0.1 1.0"/></material>
  <material name="blue"><color rgba="0.1 0.3 0.8 1.0"/></material>

  <!-- ============================================================
       base_footprint (ground projection, nav reference frame)
       ============================================================ -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       base_link (chassis)
       ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <xacro:inertial_box mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}">
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <!-- ============================================================
       Mecanum wheel macro
       prefix: fl / fr / rl / rr
       xsign/ysign: +/-1 placement
       ============================================================ -->
  <xacro:macro name="mecanum_wheel" params="prefix xsign ysign">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_width}" radius="${wheel_radius}">
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </xacro:inertial_cylinder>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${xsign*wheel_xoff} ${ysign*wheel_yoff} ${wheel_zoff}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="20.0" velocity="30.0"/>
      <dynamics damping="0.05" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:mecanum_wheel prefix="fl" xsign="1"  ysign="1"/>
  <xacro:mecanum_wheel prefix="fr" xsign="1"  ysign="-1"/>
  <xacro:mecanum_wheel prefix="rl" xsign="-1" ysign="1"/>
  <xacro:mecanum_wheel prefix="rr" xsign="-1" ysign="-1"/>

  <!-- ============================================================
       Sensors (IMU, camera, lidar) — defined in sensors.xacro
       ============================================================ -->
  <xacro:imu_sensor    parent="base_link" xyz="0 0 ${base_height+0.01}"/>
  <xacro:camera_sensor parent="base_link" xyz="${base_length/2} 0 ${base_height}"/>
  <xacro:lidar_sensor  parent="base_link" xyz="0 0 ${base_height+0.06}"/>

</robot>
