<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="omni_test_world">

    <!-- Physics / scene -->
    <gravity>0 0 -9.81</gravity>
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <scene>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.7 0.8 0.9 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ============================================================
         Test arena: a 6 m x 6 m walled room (interior -3..3 in x,y)
         with two interior obstacles. The pre-built map in
         omni_navigation/maps/test_map.* is generated to match this.
         ============================================================ -->
    <model name="arena">
      <static>true</static>

      <!-- Wall macro expanded inline: thickness 0.1, height 0.5 -->
      <!-- North wall (y = +3) -->
      <link name="wall_north">
        <pose>0 3.05 0.25 0 0 0</pose>
        <collision name="c"><geometry><box><size>6.2 0.1 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>6.2 0.1 0.5</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual>
      </link>
      <!-- South wall (y = -3) -->
      <link name="wall_south">
        <pose>0 -3.05 0.25 0 0 0</pose>
        <collision name="c"><geometry><box><size>6.2 0.1 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>6.2 0.1 0.5</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual>
      </link>
      <!-- East wall (x = +3) -->
      <link name="wall_east">
        <pose>3.05 0 0.25 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.1 6.0 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 6.0 0.5</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual>
      </link>
      <!-- West wall (x = -3) -->
      <link name="wall_west">
        <pose>-3.05 0 0.25 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.1 6.0 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 6.0 0.5</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual>
      </link>

      <!-- Interior obstacle 1: 0.6 x 0.6 box centred at (1.0, 1.0) -->
      <link name="obstacle_1">
        <pose>1.0 1.0 0.25 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.6 0.6 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.6 0.6 0.5</size></box></geometry>
          <material><ambient>0.8 0.3 0.1 1</ambient><diffuse>0.9 0.4 0.1 1</diffuse></material></visual>
      </link>

      <!-- Interior obstacle 2: 0.8 x 0.4 box centred at (-1.5, -0.8) -->
      <link name="obstacle_2">
        <pose>-1.5 -0.8 0.25 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.8 0.4 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.8 0.4 0.5</size></box></geometry>
          <material><ambient>0.1 0.3 0.8 1</ambient><diffuse>0.1 0.4 0.9 1</diffuse></material></visual>
      </link>
    </model>

    <!-- GUI camera -->
    <gui>
      <camera name="user_camera">
        <pose>0 -8 7 0 0.6 1.5708</pose>
      </camera>
    </gui>

  </world>
</sdf>
